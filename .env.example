# MiniMax API (images, voiceover, music)
MINIMAX_API_KEY=your-minimax-api-key

# Groq API (Whisper transcription for word-level captions)
GROQ_API_KEY=your-groq-api-key

# Optional: MiniMax voice ID (default: male-qn-qingse)
# See https://platform.minimax.io/docs for available voices
# VOICE_ID=male-qn-qingse
